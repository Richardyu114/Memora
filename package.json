{
  "name": "@richardyu114/moryn",
  "version": "0.1.0",
  "description": "A personal memory, skill, and soul layer for AI agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "moryn": "./dist/cli.js",
    "moryn-agent-smoke": "./scripts/agent-lifecycle-smoke.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "assets",
    "scripts/agent-lifecycle-smoke.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "release:check": "tsx scripts/release-check.ts",
    "smoke:agent-lifecycle": "node scripts/agent-lifecycle-smoke.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Richardyu114/Moryn.git"
  },
  "bugs": {
    "url": "https://github.com/Richardyu114/Moryn/issues"
  },
  "homepage": "https://github.com/Richardyu114/Moryn#readme",
  "publishConfig": {
    "access": "public"
  }
}
